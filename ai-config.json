{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "aiProvider": "openai",
  "comment": "Set aiProvider to 'openai' or 'anthropic'. Add API key as OPENAI_API_KEY or ANTHROPIC_API_KEY in GitHub Secrets",
  
  "searchPrompts": {
    "mainQuery": "Generate realistic yoga retreats, workshops, and meditation events that would typically be found in the Netherlands. Provide plausible event URLs from known booking platforms.",
    "keywords": [
      "yoga retreat Netherlands",
      "yoga workshop Amsterdam",
      "meditation retreat Holland",
      "vipassana Netherlands",
      "tantra workshop Netherlands",
      "ayurveda retreat Netherlands",
      "kundalini yoga retreat Netherlands",
      "yin yoga retreat Netherlands"
    ],
    "sources": [
      "bookretreats.com",
      "eventbrite.nl",
      "meetup.com",
      "yogapoint.nl",
      "retraite.nl"
    ],
    "urlGuidelines": [
      "Use realistic URL patterns for known booking platforms",
      "BookRetreats format: https://bookretreats.com/retreat/[retreat-name]-[location]",
      "Eventbrite format: https://www.eventbrite.nl/e/[event-name]-tickets-[id]",
      "Meetup format: https://www.meetup.com/[group-name]/events/[event-id]",
      "Studio websites: https://[studio-name].nl/retreats/[retreat-name]"
    ],
    "exclusions": [
      "online only events",
      "events outside Netherlands",
      "corporate wellness events",
      "gym fitness classes"
    ]
  },

  "ratingCriteria": {
    "description": "AI will rate events 1-5 stars based on these criteria",
    "weights": {
      "authenticReputation": 0.30,
      "venueQuality": 0.20,
      "instructorCredentials": 0.20,
      "priceValue": 0.15,
      "programDepth": 0.15
    },
    "rules": [
      {
        "condition": "Event by well-known yoga schools or certified teachers",
        "impact": "+1 star",
        "reason": "Reputable organizer"
      },
      {
        "condition": "Beautiful natural setting or dedicated retreat center",
        "impact": "+0.5 star",
        "reason": "Premium venue"
      },
      {
        "condition": "Multi-day immersive program (3+ days)",
        "impact": "+0.5 star",
        "reason": "Deep transformational experience"
      },
      {
        "condition": "Price > €500 without clear value justification",
        "impact": "-0.5 star",
        "reason": "Potentially overpriced"
      },
      {
        "condition": "Limited information about instructor/program",
        "impact": "-1 star",
        "reason": "Lacks transparency"
      },
      {
        "condition": "First-time organizer or new venue",
        "impact": "-0.5 star",
        "reason": "Unproven track record"
      }
    ],
    "minimumRating": 3.0,
    "minimumRatingNote": "Events rated below 3.0 stars will not be added to the website"
  },

  "eventValidation": {
    "requiredFields": [
      "title",
      "category",
      "type",
      "city",
      "date_start",
      "date_end",
      "organizer",
      "source_url"
    ],
    "dataQualityChecks": [
      "Date must be in future",
      "Duration must be realistic (1-30 days)",
      "City must be in Netherlands",
      "Source URL must be accessible",
      "Title must be descriptive (not generic)",
      "Description must be substantive (50+ chars)"
    ]
  },

  "deduplication": {
    "matchCriteria": [
      "Same title and organizer",
      "Same venue and dates",
      "Similar title (>80% match) within 7 days"
    ],
    "conflictResolution": "Keep event with higher rating or more complete information"
  },

  "schedule": {
    "frequency": "daily",
    "runTime": "23:30 CET",
    "maxEventsPerRun": 10,
    "maxEventsInDatabase": 150,
    "archiveAfterDays": 180
  },

  "notifications": {
    "createPullRequest": true,
    "prDescription": "Auto-generated by AI Event Scraper. Please review new events and their ratings before merging.",
    "autoMergeIfConfident": false
  }
}
